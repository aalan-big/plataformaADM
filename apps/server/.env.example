# ============================================================================
# Exemplo de variáveis de ambiente do servidor (apps/server)
# Copie para apps/server/.env e preencha. NUNCA versione o .env real.
# ============================================================================

# --- Ambiente ---------------------------------------------------------------
# Em produção DEVE ser "production" — ativa as travas de segurança
# (JWT_SECRET obrigatório, CORS restrito). O PM2 (ecosystem.config.js) já força isso.
NODE_ENV=production

# Porta HTTP da API (padrão 3001 se ausente)
PORT=3001

# --- Segurança --------------------------------------------------------------
# OBRIGATÓRIO em produção. Segredo forte e aleatório para assinar o JWT do admin.
# Gere um: openssl rand -base64 48
JWT_SECRET=

# Origens permitidas a chamar a API pelo navegador (separadas por vírgula).
# Ex.: https://admin.startbig.com.br
# Se vazio em produção, nenhum acesso cross-origin de browser é permitido.
CORS_ORIGINS=

# --- Banco de dados ---------------------------------------------------------
DATABASE_URL=
DIRECT_URL=

# --- Stripe -----------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# URL pública do app (usada nos redirects de checkout do Stripe)
APP_URL=

# --- Chaves RSA da licença (base64) ----------------------------------------
LICENCA_PRIVATE_KEY=
LICENCA_PUBLIC_KEY=

# --- E-mail (Resend e/ou SMTP) ---------------------------------------------
RESEND_API_KEY=
RESEND_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
